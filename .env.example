# Enables the Ask-the-data Q&A pipeline (server/index.mjs).
# The sundial chart works fully WITHOUT this. Answering is Anthropic-only:
# with no key the server returns a clear "AI unavailable — retry".

# Anthropic API key — used to parse the question into a Query and reword the
# final sentence. The model NEVER computes a number.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional overrides. Set ANTHROPIC_MODEL to one your key can access.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
PROSE_PORT=8787

# --- Runtime activity log (optional) ---
# DATABASE_URL: when set, the interaction log is stored in Postgres (durable
# across restarts/redeploys). Leave unset locally to use logs/activity.log.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# LOG_CLEAR_TOKEN: secret that gates the hidden log admin endpoints:
#   POST /api/log/clear   -> wipe the log back to zero
#   GET  /api/log/export  -> download the full log (newline-JSON)
# Without it, both return 404. Generate with: openssl rand -hex 32
# NEVER commit the real value (this file is an example; .env is gitignored).
# LOG_CLEAR_TOKEN=replace-with-a-long-random-string
